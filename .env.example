# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=voiceapp
POSTGRES_USER=voiceapp_user
POSTGRES_PASSWORD=your_strong_password_here

# ─── Backend ──────────────────────────────────────────────────────────────────
JWT_SECRET=your_very_long_random_jwt_secret_here

# ─── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=Vp9YxQ3zG7mK5nL8
LIVEKIT_API_SECRET=r2W4tV6uY8xZ0qB2dF4gH6jK8mN0pQ2r

# ─── AWS S3 (recordings) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=titoo-voice-recording
AWS_S3_RECORDING_FOLDER=voice-recordings
AWS_SIGNED_URL_EXPIRY=3600

# ─── CORS (comma-separated) ───────────────────────────────────────────────────
CORS_ORIGINS=https://www.rapidvoice.pro,https://rapidvoice.pro,https://api.rapidvoice.pro

# ─── Frontend build-time vars (baked into Next.js bundle) ────────────────────
# These MUST be set before running: docker compose build frontend
NEXT_PUBLIC_API_URL=https://api.rapidvoice.pro
NEXT_PUBLIC_SOCKET_URL=https://api.rapidvoice.pro
NEXT_PUBLIC_LIVEKIT_URL=wss://api.rapidvoice.pro/livekit/
